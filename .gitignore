# ===============================================
#  .gitignore
#  上海地铁路径规划与管理系统
#  (基于 GitHub C++ 标准模板，追加本项目特殊项)
# ===============================================

# ---------- 编译产物 ----------
# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll
*.so.*

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
metro.exe
*.exe
*.out
*.app

# Build directories
build/
Build/
build-*/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json

# Temporary files
*.tmp
*.log
*.bak
*.swp

# vcpkg
vcpkg_installed/

# debug information files
*.dwo

# test output & cache
Testing/
.cache/
test_auto.cpp

# ---------- IDE / 编辑器 ----------
.vscode/
.idea/
*.swo
*~
*.user
.vs/

# ---------- 个人文件 / 作业归档 (本项目特殊) ----------
*.rar
*.7z
*.zip
*.tar.gz
个人任务.*
个人作业.*

# ---------- 系统临时文件 ----------
Thumbs.db
.DS_Store

# ---------- C++ 编译中间文件 ----------
*.i
*.s
cmake-build-*/
